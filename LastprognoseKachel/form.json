                { "caption": "Heute + 2 Tage",         "value": 3 }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🎨 Darstellung",
            "expanded": false,
            "items": [
                {
                    "type": "SelectColor",
                    "name": "ColorAccent",
                    "caption": "Akzentfarbe (Median-Linie & Band)"
