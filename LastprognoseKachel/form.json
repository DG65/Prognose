{
    "elements": [
        {
            "type": "SelectInstance",
            "name": "SourceInstance",
            "caption": "Prognose-Instanz (leer = automatisch, wenn nur eine vorhanden)"
        },
        {
            "type": "Select",
            "name": "Days",
            "caption": "Anzuzeigende Tage",
