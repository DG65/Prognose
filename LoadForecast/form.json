{
    "elements": [
        {
            "type": "ExpansionPanel",
            "caption": "⚙️ Allgemein",
            "expanded": true,
            "items": [
                {
                    "type": "CheckBox",
                    "name": "LFC_Active",
                    "caption": "Prognose aktiv"
                },
                {
                    "type": "NumberSpinner",
                    "name": "LFC_IntervalHours",
                    "caption": "Neuberechnung alle … Stunden",
                    "minimum": 1,
                    "maximum": 24,
                    "suffix": " h"
                },
                {
                    "type": "Select",
                    "name": "LFC_Log_Level",
                    "caption": "Logging",
                    "options": [
                        { "caption": "Aus",      "value": 0 },
                        { "caption": "Basis",    "value": 1 },
                        { "caption": "Ausführlich","value": 2 }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "📊 Datenquellen (Archiv)",
            "expanded": true,
            "items": [
                {
                    "type": "Label",
                    "caption": "── Hauptverbrauch (Pflicht) ─────────────────────────"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_Consumption",
                    "caption": "Hausverbrauch — LEISTUNG in W (muss archiviert sein)"
                },
                {
                    "type": "Label",
                    "caption": "Tipp: z.B. die EMS-Variable 'Hausverbrauch (W)'. Für eine reine Grundlast-Prognose unten WP/Wallbox abziehen."
                },
                {
                    "type": "Label",
                    "caption": "── Abzuziehende Verbraucher (optional) ──────────────"
                },
                {
                    "type": "List",
                    "name": "ExcludeVars",
                    "caption": "Wärmepumpe, Wallbox … (Leistung in W) werden slotweise abgezogen",
                    "add": true,
                    "delete": true,
                    "columns": [
                        {
                            "caption": "Variable",
                            "name": "VariableID",
                            "width": "auto",
                            "add": 0,
                            "edit": { "type": "SelectVariable" }
                        }
                    ]
                },
                {
                    "type": "Label",
                    "caption": "── Einflussgrößen (Historie) ────────────────────────"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_TempHistory",
                    "caption": "Außentemperatur (°C, archiviert)"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_Presence",
                    "caption": "Anwesenheit (bool/0..1, archiviert) — z.B. Geofencing"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🔮 Temperaturvorhersage",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Wichtig: Es werden TAGESMITTEL erwartet (konsistent zur Historie), nicht die aktuelle Temperatur."
                },
                {
                    "type": "Select",
                    "name": "LFC_TempFcMode",
                    "caption": "Quelle der Vorhersage",
                    "options": [
                        { "caption": "Auto (OpenWeatherData, sonst Klimatologie)", "value": 0 },
                        { "caption": "Tagesmittel-Variablen",                      "value": 1 },
                        { "caption": "Slot-Aggregation über Ident-Muster",        "value": 2 }
                    ]
                },
                {
                    "type": "Label",
                    "caption": "Auto: findet eine OpenWeatherData-Instanz (demel42) automatisch. Voraussetzung: dort die Stundenvorhersage aktivieren (hourly_forecast_count > 0, z.B. 40). Ohne OWM/ohne Vorhersage wird das saisonale Normal aus dem Temperatur-Archiv genutzt."
                },
                {
                    "type": "Label",
                    "caption": "── Tagesmittel-Variablen (Modus 1) ──────────────────"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_TempFc_D0",
                    "caption": "Tagesmittel heute (°C)"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_TempFc_D1",
                    "caption": "Tagesmittel morgen (°C)"
                },
                {
                    "type": "SelectVariable",
                    "name": "VAR_TempFc_D2",
                    "caption": "Tagesmittel übermorgen (°C)"
                },
                {
                    "type": "Label",
                    "caption": "── Slot-Variablen selbst aggregieren (Modus 2) ──────"
                },
                {
                    "type": "Label",
                    "caption": "Nur nötig für andere Wettermodule (DWD, Meteoblue …). Für OpenWeatherData reicht Modus Auto. Eltern-Objekt = Instanz/Kategorie der Slot-Variablen. Muster mit %d oder %02d für den Slot-Index."
                },
                {
                    "type": "SelectInstance",
                    "name": "LFC_FcParentID",
                    "caption": "Eltern-Objekt der Slot-Variablen"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "LFC_FcTimeIdent",
                    "caption": "Ident-Muster Zeitstempel (Unix) je Slot"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "LFC_FcTempIdentLow",
                    "caption": "Ident-Muster Temperatur (bzw. Min) je Slot"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "LFC_FcTempIdentHigh",
                    "caption": "Ident-Muster Max-Temperatur (optional, dann (Min+Max)/2)"
                },
                {
                    "type": "RowLayout",
                    "items": [
                        {
                            "type": "NumberSpinner",
                            "name": "LFC_FcStartIndex",
                            "caption": "Start-Index",
                            "minimum": 0,
                            "maximum": 200
                        },
                        {
                            "type": "NumberSpinner",
                            "name": "LFC_FcCount",
                            "caption": "Anzahl Slots",
                            "minimum": 1,
                            "maximum": 200
                        }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🏠 Anwesenheit (Zukunft)",
            "expanded": false,
            "items": [
                {
                    "type": "SelectVariable",
                    "name": "VAR_PresenceFc",
                    "caption": "Geplante Anwesenheit (bool/0..1) — leer = aktueller Zustand"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🧮 Modellparameter",
            "expanded": false,
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "LFC_LookbackDays",
                    "caption": "Historie-Tiefe (Tage)",
                    "minimum": 30,
                    "maximum": 1095,
                    "suffix": " d"
                },
                {
                    "type": "NumberSpinner",
                    "name": "LFC_K",
                    "caption": "k — Anzahl ähnlicher Tage",
                    "minimum": 3,
                    "maximum": 40
                },
                {
                    "type": "NumberSpinner",
                    "name": "LFC_Latitude",
                    "caption": "Breitengrad (für Tageslänge)",
                    "digits": 3,
                    "suffix": " °"
                },
                {
                    "type": "NumberSpinner",
                    "name": "LFC_HDD_Base",
                    "caption": "Heizgrenztemperatur (Basis für Heizgrad)",
                    "digits": 1,
                    "suffix": " °C"
                },
                {
                    "type": "Select",
                    "name": "LFC_Resolution",
                    "caption": "Zeitliche Auflösung",
                    "options": [
                        { "caption": "60 Minuten (24 Slots, robust)",      "value": 60 },
                        { "caption": "30 Minuten (48 Slots)",              "value": 30 },
                        { "caption": "15 Minuten (96 Slots, Viertelstunde)","value": 15 }
                    ]
                },
                {
                    "type": "Label",
                    "caption": "Hinweis: 30/15 min werden aus den Rohwerten integriert und brauchen entsprechend feine Archivierung über den Historie-Zeitraum. Für ältere Tage ohne Rohdaten fällt die Abdeckung weg (Tag wird übersprungen). 60 min nutzt das robuste Stundenaggregat."
                },
                {
                    "type": "Select",
                    "name": "LFC_State",
                    "caption": "Bundesland (für regionale Feiertage)",
                    "options": [
                        { "caption": "— nur bundesweite —",        "value": "" },
                        { "caption": "Baden-Württemberg",          "value": "BW" },
                        { "caption": "Bayern",                     "value": "BY" },
                        { "caption": "Berlin",                     "value": "BE" },
                        { "caption": "Brandenburg",                "value": "BB" },
                        { "caption": "Bremen",                     "value": "HB" },
                        { "caption": "Hamburg",                    "value": "HH" },
                        { "caption": "Hessen",                     "value": "HE" },
                        { "caption": "Mecklenburg-Vorpommern",     "value": "MV" },
                        { "caption": "Niedersachsen",              "value": "NI" },
                        { "caption": "Nordrhein-Westfalen",        "value": "NW" },
                        { "caption": "Rheinland-Pfalz",            "value": "RP" },
                        { "caption": "Saarland",                   "value": "SL" },
                        { "caption": "Sachsen",                    "value": "SN" },
                        { "caption": "Sachsen-Anhalt",             "value": "ST" },
                        { "caption": "Schleswig-Holstein",         "value": "SH" },
                        { "caption": "Thüringen",                  "value": "TH" }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "🔥 Temperaturabhängige Geräte (optional, separate Prognose)",
            "expanded": false,
            "items": [
                {
                    "type": "Label",
                    "caption": "Separate Tagesprognose je Gerät via Temperaturregression. Heizen: kWh = a + b·Heizgrad. Kühlen: kWh = a + c·Kühlgrad. Beides (Luft-Luft-WP/Klima): V-Kurve a + b·Heizgrad + c·Kühlgrad. Benötigt Geräte-Leistung (W) + Außentemperatur im Archiv."
                },
                {
                    "type": "List",
                    "name": "WPDevices",
                    "caption": "Geräte (WP, Klima)",
                    "add": true,
                    "delete": true,
                    "columns": [
                        {
                            "caption": "Leistung (W, archiviert)",
                            "name": "PowerVar",
                            "width": "auto",
                            "add": 0,
                            "edit": { "type": "SelectVariable" }
                        },
                        {
                            "caption": "Betriebsart",
                            "name": "Mode",
                            "width": "200px",
                            "add": 0,
                            "edit": {
                                "type": "Select",
                                "options": [
                                    { "caption": "Heizen",          "value": 0 },
                                    { "caption": "Kühlen",          "value": 1 },
                                    { "caption": "Heizen + Kühlen", "value": 2 }
                                ]
                            }
                        }
                    ]
                },
                {
                    "type": "NumberSpinner",
                    "name": "LFC_CDD_Base",
                    "caption": "Kühlgrenztemperatur (Basis für Kühlgrad)",
                    "digits": 1,
                    "suffix": " °C"
                },
                {
                    "type": "Label",
                    "caption": "Hinweis: Das frühere Einzelfeld wurde durch diese Liste ersetzt. Eine bestehende Konfiguration wirkt übergangsweise als Heiz-Gerät weiter, bis du sie hier als Gerät einträgst."
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Prognose jetzt neu berechnen",
            "onClick": "LFC_Rebuild($id);"
        },
        {
            "type": "Button",
            "caption": "Status anzeigen",
            "onClick": "echo LFC_GetStatusText($id);"
        },
        {
            "type": "Button",
            "caption": "Prognose morgen (JSON) ausgeben",
            "onClick": "echo print_r(LFC_GetForecast($id, 1), true);"
        }
    ],
    "status": [
        { "code": 102, "icon": "active",   "caption": "Aktiv" },
        { "code": 104, "icon": "inactive", "caption": "Deaktiviert" }
    ]
}
